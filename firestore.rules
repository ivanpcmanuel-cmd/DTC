rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'ivanpcmanuel@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      );
    }

    function isStaff() {
      return isSignedIn() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'staff')
      );
    }

    function isViewer() {
      return isSignedIn() && (
        isStaff() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'viewer')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Rules for Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && userId == request.auth.uid && (
        incoming().role == 'viewer' ||
        incoming().role == 'staff' ||
        request.auth.token.email == 'ivanpcmanuel@gmail.com'
      );
      allow update: if isSignedIn() && userId == request.auth.uid && (
        (!incoming().diff(existing()).affectedKeys().hasAny(['role']) || isAdmin())
      );
      allow delete: if isAdmin();
    }

    // Rules for Students
    match /students/{studentId} {
      allow read: if isViewer();
      allow create, update: if isStaff() && isValidId(studentId);
      allow delete: if isAdmin();
    }

    // Rules for Courses
    match /courses/{courseId} {
      allow read: if isViewer();
      allow write: if isAdmin() && isValidId(courseId);
    }

    // Rules for Classes
    match /classes/{classId} {
      allow read: if isViewer();
      allow create, update: if isStaff() && isValidId(classId);
      allow delete: if isAdmin();
    }

    // Rules for Staff
    match /staff/{staffId} {
      allow read: if isStaff() || isAdmin();
      allow write: if isAdmin() && isValidId(staffId);
    }

    // Rules for Transactions
    match /transactions/{transactionId} {
      allow read: if isStaff() && (!existing().isAdminOnly || isAdmin());
      allow create, update: if isStaff() && isValidId(transactionId) && (!incoming().isAdminOnly || isAdmin());
      allow delete: if isAdmin();
    }

    // Rules for Notifications
    match /notifications/{notificationId} {
      allow read: if isViewer();
      allow write: if isStaff() && isValidId(notificationId);
    }

    // Rules for Settings
    match /settings/global {
      allow read: if isViewer();
      allow write: if isAdmin();
    }
  }
}
