{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profiles with system authorization roles",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "User unique identifier (auth uid)" },
        "name": { "type": "string", "description": "Full name" },
        "username": { "type": "string", "description": "Email address" },
        "role": { "type": "string", "enum": ["admin", "staff", "viewer"], "description": "System role" },
        "isFirstUser": { "type": "boolean", "description": "Whether this is the initial admin user" }
      },
      "required": ["id", "name", "username", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Student registration and tracking details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "age": { "type": "number" },
        "email": { "type": "string" },
        "phone1": { "type": "string" },
        "phone2": { "type": "string" },
        "guardianName": { "type": "string" },
        "guardianContact": { "type": "string" },
        "courseId": { "type": "string" },
        "classId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "alumni"] },
        "description": { "type": "string" },
        "behaviorNotes": { "type": "string" },
        "registrationDate": { "type": "string" },
        "acquisitionChannel": { "type": "string" },
        "birthDate": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["id", "fullName", "age", "courseId", "status", "registrationDate", "acquisitionChannel"]
    },
    "Course": {
      "title": "Course",
      "description": "Courses offered by Dosign Training Center",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "durationMonths": { "type": "number" }
      },
      "required": ["id", "name", "description", "durationMonths"]
    },
    "ClassSession": {
      "title": "ClassSession",
      "description": "Class session / turret schedule",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "courseId": { "type": "string" },
        "teacherId": { "type": "string" },
        "schedule": { "type": "string" },
        "capacity": { "type": "number" },
        "status": { "type": "string", "enum": ["excellent", "remedy", "inadequate"] }
      },
      "required": ["id", "name", "courseId", "teacherId", "schedule", "capacity", "status"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Formador or teacher information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "salary": { "type": "number" },
        "assignedClassIds": { "type": "array" },
        "evaluation": { "type": "string" }
      },
      "required": ["id", "name", "role", "salary"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial incomes and expenses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string", "enum": ["tuition", "material", "enrollment", "salary", "rent", "maintenance", "tax", "other"] },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "relatedStudentId": { "type": "string" },
        "relatedStaffId": { "type": "string" },
        "status": { "type": "string", "enum": ["paid", "pending"] },
        "isAdminOnly": { "type": "boolean" }
      },
      "required": ["id", "type", "category", "amount", "date", "description", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or category alerts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "success", "error"] },
        "category": { "type": "string", "enum": ["finance", "academic", "system"] },
        "date": { "type": "string" },
        "read": { "type": "boolean" }
      },
      "required": ["id", "title", "message", "type", "category", "date", "read"]
    },
    "SettingsDocument": {
      "title": "SettingsDocument",
      "description": "Global settings such as notification defaults",
      "type": "object",
      "properties": {
        "notifyOnEnrollment": { "type": "boolean" },
        "notifyOverduePayment": { "type": "boolean" },
        "notifyNewPayment": { "type": "boolean" },
        "notifySystem": { "type": "boolean" },
        "emailAlerts": { "type": "boolean" }
      },
      "required": ["notifyOnEnrollment", "notifyOverduePayment", "notifyNewPayment", "notifySystem", "emailAlerts"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Saved user profiles"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Registered students lists"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Courses list"
    },
    "/classes/{classId}": {
      "schema": "ClassSession",
      "description": "Classes sessions list"
    },
    "/staff/{staffId}": {
      "schema": "Staff",
      "description": "Staff roster"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "System finances"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Historical alerts"
    },
    "/settings/global": {
      "schema": "SettingsDocument",
      "description": "System configurations"
    }
  }
}
